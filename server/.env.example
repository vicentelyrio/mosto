# Generate with `cargo run --bin mosto-server -- hash-password`.
#
# IMPORTANT: wrap the value in single quotes. Argon2 hashes are full of `$`
# characters, and dotenvy treats an unquoted `$xxx` as shell-style variable
# interpolation — silently replacing it with an empty string and corrupting
# the hash. Single-quoted values are taken literally.
#
# MOSTO_OWNER_PASSWORD_HASH='$argon2id$v=19$m=...$...$...'
MOSTO_OWNER_PASSWORD_HASH=
